{
  "name": "hue-cli",
  "version": "0.1.0",
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun run scripts/build.ts",
    "build:linux": "bun build --compile --minify --external react-devtools-core --target=bun-linux-x64 --outfile hue-linux ./src/cli.ts",
    "install:global": "bun run build && mkdir -p ~/.local/bin && cp hue ~/.local/bin/hue && echo 'Installed: hue → ~/.local/bin/hue'",
    "test": "bun test"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "ink": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "node-dtls-client": "^2.0.2",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "bun-types": "latest"
  },
  "patchedDependencies": {
    "ink@5.2.1": "patches/ink@5.2.1.patch"
  }
}
